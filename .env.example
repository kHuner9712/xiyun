# Copy this file to .env before local start
# Windows: copy .env.example .env
# Linux/macOS: cp .env.example .env

# MySQL (Docker)
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_DATABASE=shopxo_dev
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_general_ci

# Host-side ports (bound to localhost by default in docker-compose)
MYSQL_HOST_PORT=13306
REDIS_HOST_PORT=16379
NGINX_HOST_PORT=8080

# uni-app API base URL for local development
UNI_APP_REQUEST_URL=http://localhost:8080/
UNI_APP_STATIC_URL=

# Privacy encryption key (AES-256-CBC) — generate with: php -r "echo bin2hex(openssl_random_pseudo_bytes(32));"
# DO NOT commit real keys to the repository
MUYING_PRIVACY_KEY=

# ⚠️ 生产环境配置说明
# 正式提审/上线时，必须在 shopxo-uniapp/.env.production 中配置：
#   UNI_APP_REQUEST_URL=https://备案域名/  （必须 HTTPS，禁止 localhost/内网IP）
#   UNI_APP_WX_APPID=正式AppID             （禁止测试号 wxda7779770f53e901）
# 微信公众平台必须配置合法 request/upload/download 域名
# 后端域名备案通过后才能作为正式合法域名
